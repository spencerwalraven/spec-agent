# ─────────────────────────────────────────────────────────────────
# SPEC Systems CRM — Environment Variables
# Copy this file to .env and fill in your values.
# All variables marked [REQUIRED] must be set or the server won't work.
# ─────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...              # [REQUIRED] console.anthropic.com
SESSION_SECRET=change-me-to-any-random-32-char-string  # [REQUIRED] for auth cookies

# ── Google ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com  # [REQUIRED] Google Cloud Console → Credentials
GOOGLE_CLIENT_SECRET=GOCSPX-xxx                  # [REQUIRED]
GOOGLE_REFRESH_TOKEN=1//xxx                      # [REQUIRED] run: npm run setup
SHEET_ID=1abc123xyz                              # [REQUIRED] from Google Sheet URL

# ── Dashboard Logins ─────────────────────────────────────────────
# Format: "name:password:role" — comma-separate multiple users
# Roles: owner | sales | field
LOGIN_USERS=john:MyPass123:owner,sarah:SalesPass:sales,mike:FieldPass:field

# ── App URL ───────────────────────────────────────────────────────
APP_URL=https://your-railway-url.up.railway.app  # [REQUIRED] set after Railway deploys

# ── Webhook Security ─────────────────────────────────────────────
# Any random string — include as X-Webhook-Secret header on manual triggers
WEBHOOK_SECRET=make-up-a-random-string-here

# ── Twilio (SMS) ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE=+16165550100    # Your Twilio number in E.164 format

# ── Stripe (online payments) ──────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx    # from Stripe Dashboard → Webhooks
STRIPE_REDIRECT_URL=https://your-railway-url.up.railway.app/invoice/paid

# ── QuickBooks (accounting sync) ──────────────────────────────────
QUICKBOOKS_CLIENT_ID=xxx           # developer.intuit.com → your app
QUICKBOOKS_CLIENT_SECRET=xxx
QUICKBOOKS_ENVIRONMENT=production  # or "sandbox" for testing
QUICKBOOKS_WEBHOOK_TOKEN=xxx       # from QB webhook settings → Verifier Token

# ── Optional Enhancements ─────────────────────────────────────────
TAVILY_API_KEY=tvly-xxx            # tavily.com — enables live material price search
GOOGLE_CALENDAR_ID=primary         # or a specific calendar ID for schedule strip
TZ_NAME=America/Detroit            # client's timezone — used for all scheduled tasks
AGENT_MODEL=claude-opus-4-5        # default model — change to claude-sonnet-4-5 to reduce cost

# ── Port (Railway sets this automatically — do not change) ────────
PORT=3000
